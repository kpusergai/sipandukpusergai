function getDaftarPegawai() {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Master_Pegawai");
    if (!sheet) return [];
    var data = sheet.getDataRange().getDisplayValues();
    return data.slice(1).map(function(r) { return r[0].toString().trim(); }).filter(Boolean);
