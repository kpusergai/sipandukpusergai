// 2. OTENTIKASI AKUN PETUGAS (ANTI-CRASH)
// =========================================================================
function cekLoginPetugas(username, password) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName("Master_User");
    if (!sheet) return { status: "ERROR", message: "Sheet 'Master_User' tidak ditemukan!" };
    
    var data = sheet.getDataRange().getDisplayValues();
    var u = username ? username.toString().trim() : "";
    var p = password ? password.toString().trim() : "";
    
    for (var i = 1; i < data.length; i++) {
      if (data[i][0].toString().trim() === u && data[i][1].toString().trim() === p) {
        return { status: "SUCCESS", user: { namaPetugas: data[i][2].toString().trim(), username: data[i][0].toString().trim() } };
      }
    }
    return { status: "WRONG", message: "Username atau Password salah!" };
  } catch (e) { return { status: "ERROR", message: e.toString() }; }
}

