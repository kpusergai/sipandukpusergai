// =========================================================================
// 4. DROPDOWN PANEL CETAK DOKUMEN
// =========================================================================
function getListCetakDokumen() {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Data_Surat");
    if (!sheet) return { stKetua: [], stSekre: [], spd: [] };
    var data = sheet.getDataRange().getDisplayValues();
    var k = [], s = [], p = [];
    data.slice(1).forEach(function(r) {
      if(r[0] && r[0].toString().trim() !== "-") k.push(r[0].toString().trim());
      if(r[2] && r[2].toString().trim() !== "-") s.push(r[2].toString().trim());
      for(var i=15; i<=19; i++) { if(r[i] && r[i].toString().trim() !== "-") p.push(r[i].toString().trim()); }
    });
    var unik = function(a) { return a.filter(function(v, i, self) { return self.indexOf(v) === i; }); };
    return { stKetua: unik(k), stSekre: unik(s), spd: unik(p) };
  } catch(e) { return { stKetua: [], stSekre: [], spd: [] }; }
}

// =========================================================================
// 5. OPERASI FORMULIR: SIMPAN DATA BARU + USER PENGGUNA (KOLOM U)
// =========================================================================
function simpanDataSurat(formData) {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Data_Surat");
    
    // Fungsi pembantu untuk memaksa tanggal ke format Indonesia: "dd-MMMM-yyyy"
    function formatTanggalIndo(tglString) {
      if (!tglString) return "";
      var d = new Date(tglString);
      if (isNaN(d.getTime())) return tglString; // Kembalikan string asli jika bukan tanggal valid
      
      // Daftar nama bulan dalam bahasa Indonesia
      var bulanIndo = [
        "Januari", "Februari", "Maret", "April", "Mei", "Juni",
        "Juli", "Agustus", "September", "Oktober", "November", "Desember"
      ];
      
      var tgl = String(d.getDate()).padStart(2, '0'); // Memastikan 2 digit (contoh: 01, 02)
      var bln = bulanIndo[d.getMonth()];            // Mengambil nama bulan dari array
      var thn = d.getFullYear();                     // Mengambil 4 digit tahun
      
      return tgl + " " + bln + " " + thn;           // Hasil akhir: 23 Juni 2026
    }

    var t1 = new Date(formData.tgl_berangkat),
        t2 = new Date(formData.tgl_kembali);
    var jlh = Math.ceil((t2 - t1) / (1000 * 3600 * 24)) + 1;

    // Menyusun baris data dengan format tanggal Indonesia yang dipaksa
    var row = [
      formData.no_surat_ketua ? "'" + formData.no_surat_ketua : "",
      formatTanggalIndo(formData.tgl_surat_ketua),
      formData.no_surat_sekre ? "'" + formData.no_surat_sekre : "",
      formatTanggalIndo(formData.tgl_surat_sekre),
      formData.pegawai1 || "",
      formData.pegawai2 || "",
      formData.pegawai3 || "",
      formData.pegawai4 || "",
      formData.pegawai5 || "",
      formData.tugas || "",
      formData.tujuan || "",
      formatTanggalIndo(formData.tgl_berangkat),
      formatTanggalIndo(formData.tgl_kembali),
      formData.kendaraan || "",
      isNaN(jlh) ? 0 : jlh,
      formData.spd1 || "",
      formData.spd2 || "",
      formData.spd3 || "",
      formData.spd4 || "",
      formData.spd5 || "",
      formData.user_aktif || "" 
    ];

    sheet.appendRow(row);
    return { status: "SUCCESS", message: "Data SPD Berhasil Disimpan dengan Format Indonesia!" };
  } catch (e) {
    return { status: "ERROR", message: e.toString() };
  }
}


// =========================================================================
// 6. OPERASI FORMULIR: UPDATE DATA EDIT BARIS + USER PENGGUNA (KOLOM U)
// =========================================================================
function updateDataSurat(noSuratLama, formData) {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Data_Surat");
    var data = sheet.getDataRange().getDisplayValues();
    var idx = -1; var no = noSuratLama ? noSuratLama.toString().trim() : "";
    for (var i = 1; i < data.length; i++) {
      if (data[i].toString().trim() === no || data[i].toString().trim() === no) { idx = i + 1; break; }
    }
    if (idx === -1) return { status: "ERROR", message: "Data tidak ditemukan!" };
    var t1 = new Date(formData.tgl_berangkat), t2 = new Date(formData.tgl_kembali);
    var jlh = Math.ceil((t2 - t1) / (1000 * 3600 * 24)) + 1;
    
    var row = [
      formData.no_surat_ketua ? "'" + formData.no_surat_ketua : "", formData.tgl_surat_ketua || "",
      formData.no_surat_sekre ? "'" + formData.no_surat_sekre : "", formData.tgl_surat_sekre || "",
      formData.pegawai1 || "", formData.pegawai2 || "", formData.pegawai3 || "", formData.pegawai4 || "", formData.pegawai5 || "",
      formData.tugas || "", formData.tujuan || "", formData.tgl_berangkat || "", formData.tgl_kembali || "", formData.kendaraan || "",
      isNaN(jlh) ? 0 : jlh, 
      formData.spd1 || "", formData.spd2 || "", formData.spd3 || "", formData.spd4 || "", formData.spd5 || "",
      formData.user_aktif || "" // <--- TETAP MEMPERTAHANKAN / MEMPERBARUI USER DI KOLOM U
    ];
    sheet.getRange(idx, 1, 1, row.length).setValues([row]);
    return { status: "SUCCESS", message: "Data Berhasil Diperbarui!" };
  } catch (e) { return { status: "ERROR", message: e.toString() }; }
}


